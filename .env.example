# ═══════════════════════════════════════════
# 故乡来信 — 环境配置模板
# ═══════════════════════════════════════════
# 使用方式：
#   cp .env.example .env
#   编辑 .env 填入你的 API Key 和代理信息
#   ./start.sh 启动（自动加载 .env）
# ═══════════════════════════════════════════

# ─── API Keys ──────────────────────────────

# DeepSeek Chat（必填）
# 国内可直接访问，无需代理
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Serper 图片/文字搜索（必填，需要代理访问）
# 这是 Google 搜索服务，国内需要走代理
SERPER_API_KEY=your-serper-api-key-here

# 火山引擎（火山方舟）图像生成（必填）
# 国内服务，无需代理
VOLC_API_KEY=ark-your-volc-api-key-here
VOLC_MODEL=ep-m-xxxxxxxxxxxxx

# ─── 代理配置 ──────────────────────────────

# 【推荐】方式一：全局代理（HTTP_PROXY / HTTPS_PROXY）
# 如果你在用 Clash，默认地址就是 http://127.0.0.1:7890
# 如果你在用 V2Ray，默认地址通常是 http://127.0.0.1:10809
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 【可选】方式二：为单个 API 单独设置代理（优先级更高）
# 只需要给 Serper 配代理，其他 API 国内可直接访问
SERPER_PROXY_URL=http://127.0.0.1:7890
# DEEPSEEK_PROXY_URL=http://127.0.0.1:7890
# VOLC_PROXY_URL=http://127.0.0.1:7890

# ─── 图片存储 ──────────────────────────────
# 开发环境使用 local；ECS 配置完成 OSS 后改为 oss
STORAGE_BACKEND=local
DEFAULT_POSTCARD_LIMIT=5
LOG_RETENTION_DAYS=7
EVENT_RETENTION_DAYS=30
ADMIN_LOG_LINES=200
OSS_URL_EXPIRE_SECONDS=900
OSS_OBJECT_PREFIX=postcards
OSS_ASSET_PREFIX=assets
# 不要把真实密钥提交到 Git；服务器上的 .env 单独配置
# OSS_ACCESS_KEY_ID=your-oss-access-key-id
# OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# ECS 后端上传使用内网 Endpoint；浏览器下载使用公网 Endpoint
# OSS_UPLOAD_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
# OSS_PUBLIC_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET_NAME=guxianglaixintest

# ─── 运行与开发者后台 ─────────────────────
APP_ENV=development
# 多个来源用逗号分隔；同源部署可以留空
ALLOWED_ORIGINS=
# 只放在服务器 .env，不要提交到 Git
ADMIN_TOKEN=replace-with-a-long-random-token

# ─── 服务配置 ──────────────────────────────
# FastAPI 服务监听端口
# HOST=0.0.0.0
# PORT=8787
